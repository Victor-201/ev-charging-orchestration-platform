# ══════════════════════════════════════════════════════════════════════
# ev-charging-orchestration-platform — deployment/docker/.env.example
# Standard: devops.skill.md Section 3.8
#
# ⚠  SECURITY: The real .env in this directory contains production
#    secrets (FCM RSA private key, JWT secret, VNPay keys, SMTP
#    credentials, Cloudinary secrets). ROTATE ALL OF THEM before
#    deploying to production. Use GitHub Actions Encrypted Secrets
#    and the hosting provider's secret store — never commit real values.
#
# Copy this file to .env and fill in real values.
# ══════════════════════════════════════════════════════════════════════

COMPOSE_PROJECT_NAME=ev_platform

# ── PostgreSQL (shared credentials; each service uses its own DB) ──────
PG_USER=ev_user
PG_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── Redis ──────────────────────────────────────────────────────────────
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD

# ── RabbitMQ ───────────────────────────────────────────────────────────
RABBITMQ_USER=ev_user
RABBITMQ_PASS=REPLACE_WITH_STRONG_RABBITMQ_PASSWORD

# ── JWT (RS256 key pair — store PEM content as single-line with \n) ────
# IAM service uses private key to sign; all others use public key to verify.
# Generate: openssl genrsa -out jwt_private.pem 2048
#           openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
JWT_SECRET=REPLACE_WITH_MIN_64_CHAR_RANDOM_STRING

# ── Cloudinary ─────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=REPLACE_WITH_CLOUDINARY_SECRET

# ── CORS ───────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:5001

# ── VNPay Payment Gateway ──────────────────────────────────────────────
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_HASH_SECRET=REPLACE_WITH_VNPAY_HASH_SECRET
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=https://your-api-domain.com/api/v1/payments/vnpay-return
VNPAY_DEEP_LINK_SCHEME=ev://app/wallet/topup/processing
ANDROID_APP_PACKAGE=com.evcharging.ev_charging_app

# ── Firebase Cloud Messaging (FCM) ─────────────────────────────────────
# ⚠ CRITICAL: The FCM_PRIVATE_KEY is an RSA private key.
#   Store it ONLY in GitHub Secrets / hosting provider vault.
#   Format: single-line with \n literals between PEM lines.
FCM_PROJECT_ID=your_firebase_project_id
FCM_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FCM_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_KEY_CONTENT\n-----END PRIVATE KEY-----\n
FCM_TEST_API_KEY=REPLACE_WITH_TEST_API_KEY

# ── ClickHouse (Telemetry) ─────────────────────────────────────────────
CLICKHOUSE_DATABASE=ev_telemetry
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=REPLACE_WITH_CLICKHOUSE_PASSWORD

# ── Grafana ────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=REPLACE_WITH_STRONG_GRAFANA_PASSWORD

# ── SMTP ───────────────────────────────────────────────────────────────
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_smtp_app_password
TEST_EMAIL_OVERRIDE=your_test_email@gmail.com

# ── Kiosk ──────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KIOSK_API_KEY=REPLACE_WITH_64_CHAR_HEX_STRING
