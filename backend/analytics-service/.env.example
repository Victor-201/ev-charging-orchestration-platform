# ==============================================================================
# analytics-service - .env.example
# ==============================================================================

# Application
NODE_ENV=development
PORT=3008

# Database
DB_HOST=localhost
DB_PORT=5440
DB_USER=ev_user
DB_PASSWORD=ev_secret
DB_NAME=ev_analytics_db

# RabbitMQ
RABBITMQ_URL=amqp://ev_user:ev_secret@localhost:5672

# Auth / JWT
JWT_PRIVATE_KEY_PATH=/var/run/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/var/run/secrets/jwt_public.pem
