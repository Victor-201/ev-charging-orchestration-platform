# ==============================================================================
# ocpp-gateway-service - .env.example
# ==============================================================================

# Application
NODE_ENV=development
PORT=3010
OCPP_WS_PORT=9001

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# OCPP Auth
# Credentials for charger WebSocket authentication (Basic Auth)
OCPP_USERNAME=admin
OCPP_PASSWORD=secret

# Auth / JWT
JWT_PRIVATE_KEY_PATH=/var/run/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/var/run/secrets/jwt_public.pem
