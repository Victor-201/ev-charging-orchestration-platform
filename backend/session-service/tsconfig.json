{
    "compilerOptions":  {
                            "module":  "commonjs",
                            "declaration":  true,
                            "removeComments":  true,
                            "emitDecoratorMetadata":  true,
                            "experimentalDecorators":  true,
                            "allowSyntheticDefaultImports":  true,
                            "esModuleInterop":  true,
                            "target":  "ES2021",
                            "sourceMap":  true,
                            "outDir":  "./dist",
                            "baseUrl":  "./",
                            "incremental":  false,
                            "skipLibCheck":  true,
                            "strictNullChecks":  true,
                            "noImplicitAny":  true,
                            "strictBindCallApply":  true,
                            "forceConsistentCasingInFileNames":  true,
                            "types":  [
                                          "jest",
                                          "node"
                                      ],
                            "paths":  {
                                          "@domain/*":  [
                                                            "src/domain/*"
                                                        ],
                                          "@application/*":  [
                                                                 "src/application/*"
                                                             ],
                                          "@infrastructure/*":  [
                                                                    "src/infrastructure/*"
                                                                ],
                                          "@shared/*":  [
                                                            "src/shared/*"
                                                        ]
                                      }
                        },
    "include":  [
                    "src/**/*.ts",
                    "test/**/*.ts"
                ],
    "exclude":  [
                    "node_modules",
                    "dist",
                    "test",
                    "**/*.spec.ts",
                    "**/*.e2e-spec.ts"
                ]
}