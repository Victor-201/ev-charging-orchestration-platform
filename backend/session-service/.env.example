# ==============================================================================
# session-service - .env.example
# ==============================================================================

# Application
NODE_ENV=production
PORT=3004

# Database (PostgreSQL)
DB_HOST=postgres-session
DB_PORT=5432
DB_USER=ev_user
DB_PASSWORD=ev_secret
DB_NAME=ev_session_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# RabbitMQ
RABBITMQ_URL=amqp://ev_user:ev_secret@rabbitmq:5672
RABBITMQ_EXCHANGE=ev.charging
RABBITMQ_PREFETCH=10

# Auth / JWT
# RS256 - Public key only (never the private key in this service)
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem
JWT_ISSUER=ev-iam-service
JWT_AUDIENCE=ev-platform

# Scheduling & Queue Weights
SCORE_W1=0.35
SCORE_W2=0.30
SCORE_W3=0.20
SCORE_W4=0.15

# Queue Management
QUEUE_REBALANCE_MS=300000
