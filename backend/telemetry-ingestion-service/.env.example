# ============================================================
# telemetry-ingestion-service — .env
# Default PORT: 3009 | No database (stateless ingestor)
# ============================================================

# ── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=3009

# ── RabbitMQ ─────────────────────────────────────────────────
# Publishes to: ev.telemetry exchange
#   routing keys: telemetry.ingested (single) | telemetry.batch (batch)
RABBITMQ_URL=amqp://ev_user:ev_secret@localhost:5672

JWT_PRIVATE_KEY_PATH=/var/run/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/var/run/secrets/jwt_public.pem

