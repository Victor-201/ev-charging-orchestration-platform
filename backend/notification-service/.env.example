# ==============================================================================
# notification-service - .env.example
# ==============================================================================

# Application
NODE_ENV=development
PORT=3004

# Database
DB_HOST=localhost
DB_PORT=5438
DB_USER=ev_user
DB_PASSWORD=ev_secret
DB_NAME=ev_notification_db

# RabbitMQ
RABBITMQ_URL=amqp://ev_user:ev_secret@localhost:5672

# SMTP / Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@ev-platform.com
SMTP_PASS=smtp-password

# Auth / JWT
JWT_PRIVATE_KEY_PATH=/var/run/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/var/run/secrets/jwt_public.pem
