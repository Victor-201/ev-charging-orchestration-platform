{
    "compilerOptions":  {
                            "module":  "commonjs",
                            "declaration":  true,
                            "removeComments":  true,
                            "emitDecoratorMetadata":  true,
                            "experimentalDecorators":  true,
                            "allowSyntheticDefaultImports":  true,
                            "esModuleInterop":  true,
                            "target":  "ES2021",
                            "sourceMap":  true,
                            "outDir":  "./dist",
                            "rootDir":  "./src",
                            "baseUrl":  "./",
                            "incremental":  false,
                            "skipLibCheck":  true,
                            "strictNullChecks":  true,
                            "noImplicitAny":  true,
                            "strictBindCallApply":  true,
                            "forceConsistentCasingInFileNames":  true,
                            "types":  [
                                          "jest",
                                          "node"
                                      ]
                        },
    "include":  [
                    "src/**/*.ts"
                ],
    "exclude":  [
                    "node_modules",
                    "dist",
                    "test",
                    "**/*.spec.ts",
                    "**/*.e2e-spec.ts"
                ]
}